# Provider credentials. Keep values empty in source control and load real credentials only from a
# private shell, secret manager, or CI environment.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
# GOOGLE_API_KEY= may be used instead of GEMINI_API_KEY.

# Live-smoke model ids must be selected deliberately because provider catalogs change over time.
AIKIT_SMOKE_ANTHROPIC_MODEL=
AIKIT_SMOKE_OPENAI_MODEL=
AIKIT_SMOKE_DEEPSEEK_MODEL=
AIKIT_SMOKE_GOOGLE_MODEL=

# Billable smoke tests remain disabled by default. Set these only on the command invocation after
# reviewing docs/LIVE-SMOKE.md; do not enable them in a shared env file.
# AIKIT_LIVE_SMOKE=1
# AIKIT_LIVE_SMOKE_FULL=1
